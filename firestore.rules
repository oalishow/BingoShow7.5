rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /events/{eventId} {
      allow get: if true; 
      allow list: if isSignedIn() && existing().hostId == request.auth.uid; 
      allow create: if isSignedIn() 
        && isValidId(eventId) 
        && incoming().hostId == request.auth.uid;
      allow update: if isSignedIn()
        && existing().hostId == request.auth.uid;
      allow delete: if isSignedIn() && existing().hostId == request.auth.uid;

      match /games/{gameId} {
        allow get, list: if true;
        allow create, update, delete: if isSignedIn()
          && get(/databases/$(database)/documents/events/$(eventId)).data.hostId == request.auth.uid;
      }
    }

    match /cards/{cardId} {
      allow get: if true;
      allow create, update: if isSignedIn()
        && incoming().hostId == request.auth.uid;
    }
  }
}
